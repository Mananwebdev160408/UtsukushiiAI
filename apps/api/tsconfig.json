{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@utsukushii/shared": ["../../../packages/shared/src/index.ts"],
      "@utsukushii/database": ["../../../packages/database/src/index.ts"],
      "@utsukushii/shared/*": ["../../../packages/shared/src/*"],
      "@utsukushii/database/*": ["../../../packages/database/src/*"]
    },
    "types": ["node"]
  },
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/database" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
