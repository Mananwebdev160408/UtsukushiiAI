{
  "name": "utsukushii-ai",
  "private": true,
  "description": "UtsukushiiAI Monorepo",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:all": "npm run docker:up && turbo run dev --parallel",
    "docker:up": "docker-compose up -d mongo redis",
    "docker:down": "docker-compose down",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "dbportal": "^1.0.2"
  }
}
